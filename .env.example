# -----------------------------------------------------------------------------
# AgileWebDevLab — environment template (NO real secrets in git)
# Copy to ".env" locally and fill values. Never commit ".env".
# -----------------------------------------------------------------------------

# Flask session signing / CSRF salt. MUST be overridden for any shared deploy.
SECRET_KEY=change-this-to-a-long-random-string

# Optional: override SQLite path (defaults to instance/lab.db when unset).
# DATABASE_URL=sqlite:////absolute/path/to/lab.db

# -----------------------------------------------------------------------------
# Lines below are documentary padding so facilitators see "secrets hygiene"
# called out explicitly during pre-release security passes. They are NOT read
# by the minimal lab app unless you later wire python-dotenv in run.py.
# -----------------------------------------------------------------------------

# FUTURE_OAUTH_CLIENT_ID=
# FUTURE_OAUTH_CLIENT_SECRET=
# FUTURE_SMTP_HOST=
# FUTURE_SMTP_USER=
# FUTURE_SMTP_PASS=
# FUTURE_SENTRY_DSN=
# FUTURE_REDIS_URL=
# FUTURE_CORS_ORIGINS=

