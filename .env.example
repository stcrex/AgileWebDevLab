SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///studysync.db
FLASK_DEBUG=True

# AI setup:
# openai = real OpenAI API using OPENAI_API_KEY
# local = built-in contextual study planner, no API key needed.
# ollama = use local Ollama if installed and running.
# openai_compatible = use LM Studio/OpenAI-compatible local server.
AI_PROVIDER=openai
OPENAI_API_KEY=REPLACE_WITH_NEW_SECRET_KEY
OPENAI_MODEL=gpt-5-mini
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.2
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:1234/v1
OPENAI_COMPATIBLE_MODEL=local-model
OPENAI_COMPATIBLE_API_KEY=not-needed
